rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requesting user is a platform admin
    function isAdmin() {
      return request.auth != null && (
        // Hardcoded safety checks for designated admin email accounts
        request.auth.token.email == "admin@gmail.com" ||
        request.auth.token.email == "royalcrmagent@gmail.com" ||
        // Check if the user document has isAdmin set to true
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }

    // Helper to check if a user is not modifying sensitive administrative or financial fields
    function isNotModifyingSensitiveFields() {
      let sensitive = ['isAdmin', 'isSuspended', 'isOnHold', 'isMaintainer', 'globalBoostRatePercent', 'balance', 'totalEarnings', 'boostEarnings', 'pausedRemainingMs', 'boostEndTime'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(sensitive);
    }

    // 1. Rules for User Profiles
    match /users/{userId} {
      // Allow authenticated users to read profiles (needed for search/transfer)
      allow read: if request.auth != null;
      
      // Allow users to create their own profile document
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // STRICT SERVER-SIDE VALIDATION ENFORCEMENT:
      // Clients can no longer update financial fields (balance, etc.) directly.
      // ALL financial transactions (Deposit, Withdraw, Transfer, Boost Earnings)
      // MUST be handled by a secure backend server / Cloud Function.
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == userId && isNotModifyingSensitiveFields())
      );

      allow delete: if isAdmin();
    }

    // 2. Rules for Transactions
    match /transactions/{transactionId} {
      // Users can see their own transactions
      allow read: if request.auth != null && (
        isAdmin() || 
        resource.data.sender == request.auth.uid || 
        resource.data.receiver == request.auth.uid
      );
      
      // Clients can only create transaction REQUESTS with status 'pending'.
      // The actual balance update and transaction 'status' (completed) 
      // MUST be processed by a secure backend server.
      allow create: if request.auth != null && (
        isAdmin() || 
        (
          request.resource.data.sender == request.auth.uid &&
          request.resource.data.status == 'pending'
        )
      );
      
      allow update, delete: if isAdmin();
    }

    // 3. Rules for Global Settings
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // 4. Rules for Email Notification System (Triggering emails)
    match /mail/{document} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }
    
    // 5. Rules for Audit Logs
    match /audit_logs/{logId} {
      // Clients can write audit logs (e.g., for integrity violations) but not read or modify them
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
  }
}
